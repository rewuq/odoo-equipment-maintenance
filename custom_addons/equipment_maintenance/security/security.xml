<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_maintenance" model="ir.module.category">
            <field name="name">Equipment Maintenance</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_maintenance_employee" model="res.groups">
            <field name="name">Співробітник</field>
            <field name="category_id" ref="module_category_maintenance"/>
        </record>

        <record id="group_maintenance_manager" model="res.groups">
            <field name="name">Менеджер</field>
            <field name="category_id" ref="module_category_maintenance"/>
            <field name="implied_ids" eval="[(4, ref('group_maintenance_employee'))]"/> 
        </record>

        <record id="rule_employee_own_requests" model="ir.rule">
            <field name="name">Співробітник: власні заявки</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_employee'))]"/>
        </record>

        <record id="rule_manager_all_requests" model="ir.rule">
            <field name="name">Менеджер: усі заявки</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_manager'))]"/>
        </record>
    </data>
</odoo>