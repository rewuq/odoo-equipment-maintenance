<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_report_pivot" model="ir.ui.view">
        <field name="name">maintenance.report.pivot</field>
        <field name="model">maintenance.report</field>
        <field name="arch" type="xml">
            <pivot string="Аналітика по обладнанню" disable_linking="True">
                <field name="equipment_id" type="row"/>
                <field name="request_count" type="measure"/>
                <field name="avg_duration" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_maintenance_report_graph" model="ir.ui.view">
        <field name="name">maintenance.report.graph</field>
        <field name="model">maintenance.report</field>
        <field name="arch" type="xml">
            <graph string="Аналітика по заявках" type="bar">
                <field name="equipment_id"/>
                <field name="request_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_maintenance_report" model="ir.actions.act_window">
        <field name="name">Звіти</field>
        <field name="res_model">maintenance.report</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <menuitem id="menu_maintenance_report" name="Звіти" parent="menu_maintenance_root" action="action_maintenance_report" sequence="40"/>
</odoo>