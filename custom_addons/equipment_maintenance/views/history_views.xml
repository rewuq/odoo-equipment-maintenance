<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_history_list" model="ir.ui.view">
        <field name="name">maintenance.history.list</field>
        <field name="model">maintenance.history</field>
        <field name="arch" type="xml">
            <list string="Історія обслуговування" create="0" edit="0" delete="0">
                <field name="equipment_id"/>
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="duration" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_maintenance_history_form" model="ir.ui.view">
        <field name="name">maintenance.history.form</field>
        <field name="model">maintenance.history</field>
        <field name="arch" type="xml">
            <form string="Запис історії" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Опис виконаних робіт">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_maintenance_history" model="ir.actions.act_window">
        <field name="name">Історія обслуговування</field>
        <field name="res_model">maintenance.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_maintenance_history" name="Історія" parent="menu_maintenance_root" action="action_maintenance_history" sequence="30"/>
</odoo>