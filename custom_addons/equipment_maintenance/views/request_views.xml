<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_request_search" model="ir.ui.view">
        <field name="name">maintenance.request.search</field>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <search string="Пошук заявок">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="user_id"/>
                <filter string="Мої заявки" name="my_requests" domain="[('user_id', '=', uid)]"/>
                <group expand="0" string="Групувати за">
                    <filter string="Статус" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Обладнання" name="group_by_equipment" context="{'group_by': 'equipment_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_maintenance_request_list" model="ir.ui.view">
        <field name="name">maintenance.request.list</field>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <list string="Заявки на обслуговування">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="request_date"/>
                <field name="user_id"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_maintenance_request_form" model="ir.ui.view">
        <field name="name">maintenance.request.form</field>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <form string="Заявка">
                <header>
                    <button name="action_in_progress" string="В роботу" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Завершити" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Скасувати" type="object" invisible="state in ('done', 'cancelled')"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="user_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="request_date"/>
                            <field name="schedule_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Опис проблеми">
                            <field name="description" placeholder="Детально опишіть проблему тут..."/>
                        </page>
                        <page string="Інформація про виконання">
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="duration"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_maintenance_request_kanban" model="ir.ui.view">
        <field name="name">maintenance.request.kanban</field>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="priority"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="priority" widget="priority"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <span>Обладнання: <field name="equipment_id"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_maintenance_request" model="ir.actions.act_window">
        <field name="name">Заявки</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_maintenance_request" name="Заявки" parent="menu_maintenance_root" action="action_maintenance_request" sequence="20"/>

</odoo>